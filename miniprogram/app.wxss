page { background: #f7f8fa; color: #1f2933; font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif; }
.card { margin: 24rpx; padding: 28rpx; border-radius: 28rpx; background: #fff; box-shadow: 0 12rpx 36rpx rgba(31, 41, 51, 0.06); }
.primary-button { border-radius: 999rpx; color: #fff; background: linear-gradient(135deg, #ff7a1a, #ffad3d); font-weight: 700; }
.price { color: #d85f00; font-weight: 800; }
.muted { color: #697586; font-size: 26rpx; }
